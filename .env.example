# GEMINI_API_KEY: Required for Gemini AI API calls in the agent chat.
# Set this in Vercel Environment Variables (Settings > Environment Variables).
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
